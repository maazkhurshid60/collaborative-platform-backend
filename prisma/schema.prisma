generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String             @id @default(uuid())
  fullName              String
  email                 String             @unique
  password              String
  profileImage          String?
  gender                Gender             @default(MALE)
  age                   Int?
  contactNo             String?
  address               String?
  status                String
  role                  Role
  isApprove             Approve            @default(PENDING)
  licenseNo             String?            @unique
  isLicenseValid        Boolean            @default(false)
  country               String
  state                 String
  blockedMembers        String[]           @default([])
  privateKey            String?
  publicKey             String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  hasUsedFreeTrial      Boolean            @default(false)
  stripeCustomerId      String?            @unique
  resetPasswordExpires  DateTime?
  resetPasswordToken    String?
  chatChannelsA         ChatChannel[]      @relation("ChatA")
  chatChannelsB         ChatChannel[]      @relation("ChatB")
  messages              ChatMessage[]
  client                Client?
  groupMemberships      GroupMembers[]
  groupReadReceipts     GroupReadReceipt[]
  receivedNotifications Notification[]     @relation("RecipientRelation")
  sentNotifications     Notification[]     @relation("SenderRelation")
  payments              Payment[]
  provider              Provider?
  readReceipts          ReadReceipt[]
  subscription          Subscription?
  superAdmin            SuperAdmin?
}

model Client {
  id                          String              @id @default(uuid())
  userId                      String              @unique
  eSignature                  String?
  isAccountCreatedByOwnClient Boolean             @default(false)
  clientShowToOthers          Boolean             @default(true)
  createdByProviderId         String?
  createdAt                   DateTime            @default(now())
  updatedAt                   DateTime            @updatedAt
  clientId                    String?             @unique
  createdBy                   Provider?           @relation("ClientCreator", fields: [createdByProviderId], references: [id])
  user                        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  receivedDocument            DocumentShareWith[]
  providerList                ProviderOnClient[]
}

model Provider {
  id             String              @id @default(uuid())
  userId         String              @unique
  department     String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  createdClients Client[]            @relation("ClientCreator")
  sharedDocument DocumentShareWith[]
  groupChats     GroupChat[]
  invitations    Invitation[]
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientList     ProviderOnClient[]
}

model SuperAdmin {
  id        String   @id @default(uuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatChannel {
  id          String        @id @default(uuid())
  providerAId String
  providerBId String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedByA  Boolean       @default(false)
  deletedByB  Boolean       @default(false)
  providerA   User          @relation("ChatA", fields: [providerAId], references: [id], onDelete: Cascade)
  providerB   User          @relation("ChatB", fields: [providerBId], references: [id], onDelete: Cascade)
  messages    ChatMessage[]

  @@unique([providerAId, providerBId])
}

model ChatMessage {
  id                String             @id @default(uuid())
  chatChannelId     String?
  groupId           String?
  senderId          String
  message           String
  mediaUrl          String?
  type              String
  createdAt         DateTime           @default(now())
  chatChannel       ChatChannel?       @relation(fields: [chatChannelId], references: [id])
  group             GroupChat?         @relation(fields: [groupId], references: [id])
  sender            User               @relation(fields: [senderId], references: [id], onDelete: Cascade)
  groupReadReceipts GroupReadReceipt[]
  readReceipts      ReadReceipt[]
}

model Document {
  id         String              @id @default(uuid())
  url        String
  name       String
  type       String?             @default("Questionnaire")
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  sharedWith DocumentShareWith[]
}

model DocumentShareWith {
  id         String    @id @default(uuid())
  documentId String
  clientId   String?
  providerId String?
  eSignature String?
  isAgree    Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  client     Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  document   Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  provider   Provider? @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([documentId, clientId, providerId])
}

model GroupChat {
  id         String         @id @default(uuid())
  name       String
  providerId String
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  messages   ChatMessage[]
  provider   Provider       @relation(fields: [providerId], references: [id], onDelete: Cascade)
  members    GroupMembers[]
}

model GroupMembers {
  id          String    @id @default(uuid())
  groupChatId String
  userId      String
  createdAt   DateTime  @default(now())
  groupChat   GroupChat @relation(fields: [groupChatId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GroupReadReceipt {
  id        String      @id @default(uuid())
  messageId String
  userId    String
  readAt    DateTime    @default(now())
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
}

model Invitation {
  id          String           @id @default(uuid())
  token       String           @unique
  email       String
  invitedById String
  status      InvitationStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  invitedBy   Provider         @relation(fields: [invitedById], references: [id])
}

model Notification {
  id                 String           @id @default(uuid())
  title              String
  message            String
  type               NotificationType
  recipientId        String
  senderId           String?
  seen               Boolean          @default(false)
  deletedBySender    Boolean          @default(false)
  deletedByRecipient Boolean          @default(false)
  createdAt          DateTime         @default(now())
  recipient          User             @relation("RecipientRelation", fields: [recipientId], references: [id], onDelete: Cascade)
  sender             User?            @relation("SenderRelation", fields: [senderId], references: [id], onDelete: Cascade)
}

model ProviderOnClient {
  id         String   @id @default(uuid())
  clientId   String
  providerId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
}

model ReadReceipt {
  id        String      @id @default(uuid())
  messageId String
  userId    String
  readAt    DateTime    @default(now())
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
}

model Subscription {
  id                   String             @id @default(uuid())
  userId               String             @unique
  stripeCustomerId     String?
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  plan                 PlanType           @default(STANDARD)
  status               SubscriptionStatus @default(TRIALING)
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  billingCycle         String?
  cancelReason         String?
  trialEnd             DateTime?
  trialStart           DateTime?
  user                 User               @relation(fields: [userId], references: [id])
}

model Payment {
  id                    String        @id @default(uuid())
  userId                String
  stripePaymentIntentId String?
  stripeInvoiceId       String?       @unique
  amount                Int
  currency              String
  status                PaymentStatus @default(PENDING)
  invoiceUrl            String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  plan                  String?
  paymentMethodLast4    String?
  periodEnd             DateTime?
  periodStart           DateTime?
  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  OVERDUE
  CANCELED
}

enum Gender {
  MALE
  FEMALE
}

enum Role {
  superAdmin
  client
  provider
}

enum Approve {
  PENDING
  APPROVED
  REJECTED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

enum NotificationType {
  PROFILE_UPDATE
  PASSWORD_UPDATE
  DOCUMENT_SHARED
  DOCUMENT_SIGNED
}

enum PlanType {
  STANDARD
  PRO
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  CANCELED
  PAST_DUE
  UNPAID
  INCOMPLETE
  INCOMPLETE_EXPIRED
  PAUSED
}
